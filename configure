#!/bin/sh
set -e

: "${R_HOME=$(R RHOME)}"
if [ -z "${R_HOME}" ]; then
    echo "configure: could not determine R_HOME" >&2
    exit 1
fi
R_BIN="${R_HOME}/bin/R"

CC=$("${R_BIN}" CMD config CC)
CFLAGS=$("${R_BIN}" CMD config CFLAGS)
CPPFLAGS=$("${R_BIN}" CMD config CPPFLAGS)
CPICFLAGS=$("${R_BIN}" CMD config CPICFLAGS)
AR=$("${R_BIN}" CMD config AR)
RANLIB=$("${R_BIN}" CMD config RANLIB)
: "${AR:=ar}"
: "${RANLIB:=ranlib}"


EXT="src/ext-lib"
BUILD="${EXT}/build"
LIB="${BUILD}/libMovingAverage.a"

mkdir -p "${BUILD}"

OBJS=""
for src in "${EXT}"/src/*.c; do
    obj="${src%.c}.o"
    echo "configure: compiling ${src}"
    ${CC} ${CPPFLAGS} ${CFLAGS} ${CPICFLAGS} -I"${EXT}/include" -c "${src}" -o "${obj}"
    OBJS="${OBJS} ${obj}"
done

rm -f "${LIB}"
${AR} rcs "${LIB}" ${OBJS}
${RANLIB} "${LIB}"


cat > src/Makevars <<'EOF'
# Generated by ./configure do not edit (edit configure instead).
PKG_CPPFLAGS = -I$(CURDIR)/ext-lib/include
PKG_LIBS = -L$(CURDIR)/ext-lib/build -lMovingAverage
$(SHLIB): ext-lib/build/libMovingAverage.a
EOF

echo "configure: wrote src/Makevars"
exit 0
